    "es-toolkit": "1.45.1",
    "favico.js": "0.3.10",
    "fontfaceobserver": "2.3.0",
    "mobx": "6.15.0",
    "mobx-react-lite": "4.1.1",
    "promise-retry": "2.0.1",
    "react": "19.2.4",
    "react-cool-dimensions": "3.0.1",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
